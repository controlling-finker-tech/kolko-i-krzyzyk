          {
            "name": "Liczba schronisk, w których przebywały psy",
            "dataType": "int64",
            "lineageTag": "c001-0000-0000-0000-000000000009",
            "summarizeBy": "sum",
            "sourceColumn": "Liczba schronisk, w których przebywały psy",
            "annotations": [
              { "name": "SummarizationSetBy", "value": "Automatic" }
            ]
          }
        ],
        "measures": [
          {
            "name": "Wskaźnik adopcji psów [%]",
            "expression": "DIVIDE(SUM('Schroniska'[Liczba psów adoptowanych ze schronisk]), SUM('Schroniska'[Liczba psów w schroniskach]), 0) * 100",
            "formatString": "0.00",
            "lineageTag": "m001-0000-0000-0000-000000000001",
            "annotations": [
              { "name": "PBI_FormatHint", "value": "{\"isCustom\":true}" }
            ]
          },
          {
            "name": "Wskaźnik adopcji kotów [%]",
            "expression": "DIVIDE(SUM('Schroniska'[Liczba kotów adoptowanych ze schronisk]), SUM('Schroniska'[Liczba kotów w schroniskach]), 0) * 100",
            "formatString": "0.00",
            "lineageTag": "m001-0000-0000-0000-000000000002",
            "annotations": [
              { "name": "PBI_FormatHint", "value": "{\"isCustom\":true}" }
            ]
          },
          {
            "name": "Schronisk w 2024",
            "expression": "CALCULATE(MAX('Schroniska'[Liczba wszystkich schronisk]), 'Schroniska'[Rok] = 2024)",
            "formatString": "0",
            "lineageTag": "m001-0000-0000-0000-000000000003"
          },
          {
            "name": "Łączne adopcje psów",
            "expression": "SUM('Schroniska'[Liczba psów adoptowanych ze schronisk])",
            "formatString": "#,0",
            "lineageTag": "m001-0000-0000-0000-000000000004"
          },
          {
            "name": "Łączne adopcje kotów",
            "expression": "SUM('Schroniska'[Liczba kotów adoptowanych ze schronisk])",
            "formatString": "#,0",
            "lineageTag": "m001-0000-0000-0000-000000000005"
          }
        ],
        "partitions": [
          {
            "name": "Partition",
            "mode": "import",
            "source": {
              "type": "m",
              "expression": [
                "let",
